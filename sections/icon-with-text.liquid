<div class="icon-with-text-2">
  <div class="icon-grid page-width page-width-desktop">
    
    {% for block in section.blocks %}
      <div class="icon-box" {{ block.shopify_attributes }}>
        
       {% if block.settings.icon != blank %}
  <div class="icon-circle">
    <img 
      src="{{ block.settings.icon | image_url: width: 60 }}" 
      alt="icon"
      width="60"
      height="60"
    />
  </div>
{% endif %}
        
        {% if block.settings.heading != blank %}
          <h3 style="margin:0; font-weight:500">{{ block.settings.heading }}</h3>
        {% endif %}
        
        {% if block.settings.text != blank %}
          <p style="margin:5px 0; font-size:13px">{{ block.settings.text }}</p>
        {% endif %}

      </div>
    {% endfor %}

  </div>
</div>

{% schema %}
{
  "name": "Icons With Text",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "icon_item",
      "name": "Icon Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Heading"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Description..."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Icons With Text",
      "blocks": [
        { "type": "icon_item" },
        { "type": "icon_item" },
        { "type": "icon_item" }
      ]
    }
  ]
}
{% endschema %}